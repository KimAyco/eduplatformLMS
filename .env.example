# Application
APP_NAME=EduPlatform
APP_ENV=local
APP_DEBUG=false
# Leave empty to auto-detect (/LMS on XAMPP subfolder, blank at domain root on Hostinger)
BASE_URL=/LMS

# Database
DB_HOST=localhost
DB_NAME=lms_saas
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Session & Security
SESSION_LIFETIME=7200
SESSION_COOKIE_DOMAIN=
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
# Required for school subdomain login bridge (optional — auto-derived from DB credentials if empty)
SUBDOMAIN_LOGIN_SECRET=

# Super Admin (used by install.php — set before first install)
SUPER_ADMIN_EMAIL=superadmin@platform.local
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=Platform
SUPER_ADMIN_LAST_NAME=Owner
